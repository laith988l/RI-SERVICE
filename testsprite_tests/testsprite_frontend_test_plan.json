      }
    ]
  },
  {
    "id": "TC004",
    "title": "Edit an existing resource and verify updated content appears in the list",
    "description": "Verifies an admin can edit an existing resource and see the updated value reflected in the resources list.",
    "category": "Admin Dashboard",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email input field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "action",
        "description": "Click \"Edit\" on the first resource in the list"
      },
      {
        "type": "action",
        "description": "Type \"Updated Resource Name\" into the Name (or Title) field"
      },
      {
        "type": "action",
        "description": "Click \"Save\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Updated Resource Name\" is visible"
      }
    ]
  },
  {
