[
  {
    "id": "TC001",
    "title": "Login and create a new resource successfully from the Admin Dashboard",
    "description": "Verifies an authenticated admin can add a new resource and see it appear in the resources list.",
    "category": "Admin Dashboard",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email input field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "assertion",
        "description": "Verify URL contains \"/admin\""
      },
      {
        "type": "action",
        "description": "Click \"Add new resource\""
      },
      {
        "type": "action",
        "description": "Type \"E2E Test Resource\" into the Name (or Title) field"
      },
      {
        "type": "action",
        "description": "Click \"Save\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"E2E Test Resource\" is visible"
      }
    ]
  },
  {
