  {
    "id": "TC007",
    "title": "Submit contact form successfully with valid inputs",
    "description": "Verifies a visitor can submit the contact form with valid name, email, and message and sees a success confirmation.",
    "category": "Contact Form",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /contact"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Contact\" is visible"
      },
      {
        "type": "action",
        "description": "Fill \"Alex Tester\" into the name field"
      },
      {
        "type": "action",
        "description": "Fill \"alex.tester@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Fill \"Hello, I would like more information about your services.\" into the message field"
      },
      {
        "type": "action",
        "description": "Click on the \"Submit\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Thank you\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify text \"success\" is visible"
      }
    ]
  },
