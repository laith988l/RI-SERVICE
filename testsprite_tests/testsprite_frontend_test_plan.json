  {
    "id": "TC003",
    "title": "Create resource validation: saving with required fields empty shows errors and does not create resource",
    "description": "Verifies required-field validation appears when attempting to save an empty new resource form and no new item is added.",
    "category": "Admin Dashboard",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email input field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password input field"
      },
      {
        "type": "action",
        "description": "Click the \"Login\" button"
      },
      {
        "type": "action",
        "description": "Click \"Add new resource\""
      },
      {
        "type": "action",
        "description": "Click \"Save\""
      },
      {
        "type": "assertion",
